# Build stage
FROM node:24-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ARG SNOWPACK_PUBLIC_GRAPHQL_ENDPOINT
ARG SNOWPACK_PUBLIC_BACKEND_ENDPOINT
ENV SNOWPACK_PUBLIC_GRAPHQL_ENDPOINT=${SNOWPACK_PUBLIC_GRAPHQL_ENDPOINT}
ENV SNOWPACK_PUBLIC_BACKEND_ENDPOINT=${SNOWPACK_PUBLIC_BACKEND_ENDPOINT}

RUN npm run build

# Runtime stage: nginx serves the built frontend
FROM nginx:1.28-alpine

RUN apk del -r nginx \
  && apk add --no-cache \
      nginx \
      nginx-mod-http-vts \
      nginx-mod-http-brotli \
      nginx-mod-http-cache-purge \
      nginx-mod-http-headers-more

COPY nginx-default.conf /etc/nginx/conf.d/default.conf
COPY nginx.conf /etc/nginx/nginx.conf
COPY --from=build /app/build /usr/share/nginx/html
EXPOSE 80
